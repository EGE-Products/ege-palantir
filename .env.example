# Palantír environment configuration.
# Copy to .env and fill in values for local dev:  cp .env.example .env

# === Supabase (Red Book schema target) ===========================
# Phase 1 staging DB. Production values live in Fly secrets (EGE-206).
SUPABASE_DB_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres
SUPABASE_SERVICE_ROLE_KEY=

# === Outbound webhook ============================================
# Temporary unsigned webhook target for downstream consumers.
# Replaced by signed-webhook path in Phase 1 (see EGE-218).
TMP_WEBHOOK_URL=
TMP_WEBHOOK_SECRET=

# === Palantír runtime ============================================
PALANTIR_LOG_LEVEL=INFO

# === Prefect API endpoint ========================================
# Inside the compose network, workers reach the server by service name.
# Override to http://localhost:4200/api when running palantir from the
# host (outside compose).
PREFECT_API_URL=http://prefect-server:4200/api
